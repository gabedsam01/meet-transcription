# Copy to .env and fill in. docker compose reads this file for ${VAR} substitution.
# PostgreSQL is the single source of truth — there is NO SQLite mode.
#
# Generate a strong APP_SECRET_KEY:
#   python - <<'PY'
#   import secrets; print(secrets.token_urlsafe(48))
#   PY

# ---- Web / Admin ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Session signing AND the Fernet encryption key for stored tokens / Deepgram keys.
APP_SECRET_KEY=
# Set to true when serving over HTTPS (production).
SESSION_COOKIE_SECURE=false

# ---- Google OAuth (Web application credentials) ----
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
# Must match the authorized redirect URI in Google Cloud, character for character.
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# ---- Database (PostgreSQL, required — single source of truth) ----
# DATABASE_URL must be a PostgreSQL URL whose user/password/db match the POSTGRES_*
# values below. Use host `postgres` inside Docker Compose, or `localhost` for a
# local PostgreSQL. NEVER point this at a SQLite file path.
DATABASE_URL=postgresql+psycopg://meet_user:change_me@postgres:5432/meet_transcription
POSTGRES_DB=meet_transcription
POSTGRES_USER=meet_user
POSTGRES_PASSWORD=change_me

# ---- Worker service (python -m app.worker.main) ----
# Backend default is 'postgres' (production). 'memory' is for dev/tests ONLY and
# is FORBIDDEN in production. The worker reuses DATABASE_URL and APP_SECRET_KEY.
WORKER_REPOSITORY_BACKEND=postgres
WORKER_POLL_INTERVAL_SECONDS=30
WORKER_CONCURRENCY=1
STALE_JOB_TIMEOUT_MINUTES=30
# Queue consumer threads in redis mode (must be >= CLOUD_TRANSCRIPTION_CONCURRENCY
# to actually run that many cloud jobs in parallel).
TRANSCRIPTION_QUEUE_CONCURRENCY=5

# ---- Shared ----
TMP_DIR=/app/tmp

# ---- Transcription providers (Models tab) ----
# Cloud provider API keys (Deepgram / OpenRouter / Gemini) are PER-USER and saved
# encrypted in the database via the Models tab (/models) — there are NO env vars
# for them and NO global key. Each user selects a primary provider + model, an
# optional fallback, and supplies their own key. See documentation/20-models-tab.md
# and documentation/21-provider-registry.md.

# ---- Redis queue + locks + provider concurrency ----
# QUEUE_BACKEND: redis (production) | memory (single-process dev) | none (legacy
# poll loop). With redis, web enqueues job ids and the worker consumes them with
# provider-aware concurrency (cloud in parallel, local one at a time).
QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=transcription
TRANSCRIPTION_GLOBAL_LOCK_TTL_SECONDS=14400
# Cloud providers (Deepgram, I/O-bound) run several at once; local CPU engines run
# one at a time. A slot is reclaimed if its holder dies (after PROVIDER_LOCK_TTL).
CLOUD_TRANSCRIPTION_CONCURRENCY=5
LOCAL_TRANSCRIPTION_CONCURRENCY=1
PROVIDER_LOCK_TTL_SECONDS=14400

# ---- Retry / backoff / dead-letter ----
# Transient failures (429, rate limit, transient errors) retry with exponential
# backoff up to JOB_MAX_ATTEMPTS, then the job is dead-lettered (status=failed,
# shown in the UI with a "Tentar novamente" button). Terminal errors (invalid key,
# invalid model, file too large) never retry.
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BASE_SECONDS=60
JOB_RETRY_MAX_SECONDS=3600

# ---- Auto-poll (worker scans each enabled user's Drive folder) ----
# OFF by default: a fresh deploy must not crawl Drive before the user reviews
# their folder/provider/limits. Automation is opt-in per user via the UI
# (/settings/automation). Flip to true only to allow the loop to run at all; even
# then it polls a user only after they enable it. These are the global loop limits.
AUTO_POLL_ENABLED=false
AUTO_POLL_INTERVAL_SECONDS=300
AUTO_POLL_MAX_USERS_PER_TICK=50
AUTO_POLL_MAX_FILES_PER_USER=5
AUTO_POLL_LOCK_TTL_SECONDS=240

# ---- Cost guardrails (0 = unlimited; per-user settings override these) ----
MAX_FILE_SIZE_MB=0
DAILY_JOBS_LIMIT=0

# ---- Local CPU transcription (OFF by default → per-user Deepgram is used) ----
# When enabled AND valid, the worker transcribes locally and no Deepgram key is
# required. When enabled but INVALID, the UI shows an error + the docs link and a
# Deepgram key is required. See docs/architecture/local-transcription.md.
LOCAL_TRANSCRIPTION_ENABLED=false
# Engine: faster-whisper | whisper-cpp
LOCAL_TRANSCRIPTION_ENGINE=faster-whisper
# Model (multilingual; do NOT use .en models — we need pt-BR + English):
#   tiny | base | small | medium | large-v1 | large-v2 | large-v3 | large-v3-turbo
LOCAL_TRANSCRIPTION_MODEL=small
# Language: auto | pt | en | ...
LOCAL_TRANSCRIPTION_LANGUAGE=auto
LOCAL_TRANSCRIPTION_THREADS=4
LOCAL_TRANSCRIPTION_MODEL_DIR=/models
LOCAL_TRANSCRIPTION_DOC_URL=https://github.com/gabedsam01/meet-transcription/blob/main/docs/architecture/local-transcription.md
# Do not download models at runtime unless this is true (faster-whisper).
LOCAL_TRANSCRIPTION_AUTO_DOWNLOAD=false

# faster-whisper only — CPU compute type: int8 | int8_float32 | float32
LOCAL_TRANSCRIPTION_COMPUTE_TYPE=int8

# whisper.cpp only — set ENGINE=whisper-cpp to use these:
#   quantization: q4_0 | q4_1 | q5_0 | q5_1 | q8_0
LOCAL_TRANSCRIPTION_QUANTIZATION=q4_0
LOCAL_TRANSCRIPTION_MODEL_PATH=/models/ggml-small-q4_0.bin
WHISPER_CPP_BINARY=/usr/local/bin/whisper-cli

# ---- Audio preprocessing (OFF by default) ----
# When enabled the worker fast-fails a recording with no audio track; the
# probe/extract/compress/chunk/stitch helpers are also a library for size-limited
# providers. Needs ffmpeg/ffprobe (INSTALL_WHISPER_CPP or INSTALL_LOCAL_TRANSCRIPTION).
# See documentation/24-audio-preprocessing.md.
AUDIO_PREPROCESSING_ENABLED=false
AUDIO_TARGET_SAMPLE_RATE=16000
AUDIO_TARGET_CHANNELS=1
AUDIO_TARGET_BITRATE=24000
AUDIO_CHUNK_MAX_DURATION_SECONDS=900
AUDIO_CHUNK_OVERLAP_SECONDS=2
# Safe raw-size tiers (Gemini-style inline / Files API limits) for the chunking lib.
AUDIO_MAX_INLINE_MB=70
AUDIO_MAX_FILE_API_MB=99

# ---- Local diarization (OFF by default) ----
# Optional speaker labels via pyannote.audio (CPU; build with INSTALL_PYANNOTE=true).
# DIARIZATION_AUTH_TOKEN is a Hugging Face token — a SECRET; never commit it.
# When enabled but invalid: REQUIRED=false continues without speakers (warning),
# REQUIRED=true fails the job with a friendly message. See documentation/26-diarization.md.
DIARIZATION_ENABLED=false
# Engine: none | pyannote
DIARIZATION_ENGINE=none
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
DIARIZATION_AUTH_TOKEN=
DIARIZATION_REQUIRED=false
# Optional speaker-count hints (leave blank to auto-detect):
DIARIZATION_MIN_SPEAKERS=
DIARIZATION_MAX_SPEAKERS=

# ---- Chrome extension recording upload (OFF by default) ----
# POST /api/recordings/upload is DISABLED until EXTENSION_UPLOAD_TOKEN is set. The
# extension authenticates with this token (Authorization: Bearer). The web service
# only stores the recording + creates a pending job; the worker transcribes it.
# See documentation/27-chrome-extension.md.
EXTENSION_UPLOAD_TOKEN=
EXTENSION_UPLOAD_MAX_MB=500
# Account the uploaded jobs belong to (blank -> the ADMIN_USERNAME account).
EXTENSION_UPLOAD_USER_EMAIL=
# Shared dir for uploaded recordings (under the ./data volume; web writes, worker reads).
EXTENSION_RECORDINGS_DIR=/app/data/recordings

# ---- Build/install toggles (Docker build args, NOT runtime) ----
# Set as --build-arg when building the image; never installed at startup.
INSTALL_LOCAL_TRANSCRIPTION=false
INSTALL_FASTER_WHISPER=false
INSTALL_WHISPER_CPP=false
# pyannote.audio + torch (very large) for local diarization.
INSTALL_PYANNOTE=false

# ============================================================================
# Legacy "Simple Worker Mode" (python -m app.main) — CLI compatibility ONLY.
# NOT part of the web + worker + postgres architecture; safe to ignore unless you
# deliberately run the original env-driven CLI worker. DEEPGRAM_API_KEY below is
# consumed ONLY by this legacy CLI; the Web UI uses per-user encrypted keys saved
# in the app, never this env var.
# ============================================================================
DEEPGRAM_API_KEY=your_deepgram_api_key
GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=/app/secrets/oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=/app/secrets/token.json
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/service-account.json
SOURCE_DRIVE_FOLDER_ID=your_source_drive_folder_id
DESTINATION_DRIVE_FOLDER_ID=your_destination_drive_folder_id
STATE_FILE=/app/data/processed_files.json
MAX_PROCESSING_ATTEMPTS=2
FAILED_RETRY_AFTER_SECONDS=86400
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=pt-BR
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_PUNCTUATE=true
DEEPGRAM_DIARIZE=true
DEEPGRAM_UTTERANCES=true
