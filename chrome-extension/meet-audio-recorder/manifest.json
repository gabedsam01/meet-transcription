{
  "manifest_version": 3,
  "name": "Meet Audio Recorder",
  "version": "0.1.0",
  "description": "Records Google Meet tab audio (and optionally your mic) with one click and uploads the recording to the Meet Transcription backend.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Meet Audio Recorder",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
