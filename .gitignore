# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Environment and credentials
.env
.env.*
!.env.example
**/service-account.json
**/oauth-client.json
**/token.json
secrets/*.json
secrets/*
!secrets/.gitkeep

# Runtime data
tmp/*
!tmp/.gitkeep
data/processed_files.json
data/*.tmp
# Chrome-extension recording uploads (shared web/worker volume) — never commit.
data/recordings/
!data/.gitkeep

# Local model files downloaded by the model manager / model-init (keep the dir).
models/*
!models/.gitkeep

# OS/editor
.DS_Store
.idea/
.vscode/
